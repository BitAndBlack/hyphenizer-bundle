{
    "name": "bitandblack/hyphenizer-bundle",
    "description": "Perfect hyphenation for your Website. This library integrates the Hyphenizer into your Symfony project.",
    "license": "MIT",
    "type": "symfony-bundle",
    "authors": [
        {
            "name": "Tobias Köngeter",
            "email": "hello@bitandblack.com",
            "homepage": "https://www.bitandblack.com"
        }
    ],
    "homepage": "https://www.hyphenizer.com",
    "support": {
        "email": "hello@bitandblack.com",
        "issues": "https://bitbucket.org/wirbelwild/bit-black-sitemap/issues"
    },
    "funding": [
        {
            "type": "buymeacoffee",
            "url": "https://www.buymeacoffee.com/tobiaskoengeter"
        }
    ],
    "require": {
        "php": ">=8.2",
        "bitandblack/hyphenizer-sdk-php": "^0",
        "kiwa/hyphenizer": "^1.0",
        "nyholm/psr7": "^1.0",
        "symfony/console": "^7.0 || ^8.0",
        "symfony/framework-bundle": "^7.0 || ^8.0",
        "symfony/http-client": "^7.0 || ^8.0",
        "twig/twig": "^3.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^13.0",
        "rector/rector": "^2.0",
        "symplify/easy-coding-standard": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "BitAndBlack\\HyphenizerBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BitAndBlack\\HyphenizerBundle\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        },
        "sort-packages": true
    },
    "extra": {
        "symfony": {
            "allow-contrib": false
        }
    },
    "scripts": {
        "phpstan": "php vendor/bin/phpstan analyse --configuration ./phpstan.neon --memory-limit=-1 --ansi",
        "phpunit": "php bin/phpunit --colors=always",
        "refactor": "php vendor/bin/rector && php vendor/bin/ecs --fix"
    },
    "scripts-descriptions": {
        "phpstan": "Runs PHPStan over the src folder and the tests folder. This setting is meant to be used in the `dev` environment.",
        "phpunit": "Runs PHPUnit.",
        "refactor": "Runs tools to refactor the code."
    }
}
